programa
{
    funcao inicio()
    {
        inteiro numeroSecreto = 27
        inteiro numero

        escreva("Digite um número para descobrir o numero secreto: ")
        leia(numero)

        enquanto (numero != numeroSecreto)
        {
            escreva("Você errou, tente novamente.\n")
            escreva("Digite um número para descobrir o numero secreto: ")
            leia(numero)
        }

        escreva("Parabéns você descobriu o numero secreto!")
    }
}
